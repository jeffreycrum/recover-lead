# Database
DATABASE_URL=postgresql+asyncpg://recoverlead:recoverlead_dev@localhost:5432/recoverlead

# Redis
REDIS_URL=redis://localhost:6379/0

# Clerk
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Embedding
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Encryption (generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Observability
SENTRY_DSN=

# CORS
CORS_ORIGINS=http://localhost:3000

# Storage (Railway: mount volume at /data, local: use relative path)
SCRAPER_ARTIFACTS_DIR=/data/scraper_artifacts

# Skip trace provider (Tracerfy)
SKIP_TRACE_API_KEY=

# Physical mail via Lob
LOB_API_KEY=

# Email (SendGrid)
SENDGRID_API_KEY=

# Celery (defaults derived from REDIS_URL — override here if needed)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Frontend (Vite) — copy to frontend/.env.local for local dev
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# TLS allowlist for county scraper sites with bad certs (comma-separated hostnames)
SCRAPER_ALLOW_UNVERIFIED_HOSTS=

# App
ENVIRONMENT=development
